<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NervaOneWalletMiner.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:DataType="vm:SweepBelowViewModel"
             x:Class="NervaOneWalletMiner.Views.SweepBelowView">

	<Design.DataContext>
		<vm:SweepBelowViewModel/>
	</Design.DataContext>

	<ScrollViewer>
		<StackPanel HorizontalAlignment="Stretch"
					Spacing="5"
					Margin="10"
					MaxWidth="650">

			<Grid ColumnDefinitions="32,*">
				<Image Grid.Column="0"
					   Name="imgCoinIcon"/>
				<Label Grid.Column="1"
					   Content="Sweep Below"
					   Height="24"
					   Margin="5,0,0,0"/>
			</Grid>

			<TextBlock Margin="0,10,0,0" TextWrapping="Wrap">
				Combines small outputs (e.g. mining rewards) that may cause transfers to fail. All unlocked outputs below the threshold amount are swept to the specified address.
			</TextBlock>

			<Border Margin="0,10,0,0"
					BorderThickness="1"
					CornerRadius="4"
					Padding="10">
				<StackPanel Spacing="4">
					<TextBlock FontWeight="Bold" Text="Warning"/>
					<TextBlock TextWrapping="Wrap">
						This can take a very long time if your wallet has many outputs below the sweep amount.
					</TextBlock>
				</StackPanel>
			</Border>

			<Label Content="Amount to sweep below:" Margin="0,10,0,0"/>
			<TextBox Name="tbxAmount" Text="0.5"/>

			<Label Content="Address to send swept funds to:" Margin="0,10,0,0"/>
			<TextBox Name="tbxAddress" Watermark="Wallet address"/>

			<StackPanel Orientation="Horizontal" Spacing="10" Margin="0,20,0,0">
				<Button Name="btnRun"
						Content="Run Sweep Below"
						Click="RunButton_Clicked"/>
				<Button Name="btnCancel"
						Content="Cancel"
						Click="CancelButton_Clicked"/>
			</StackPanel>

		</StackPanel>
	</ScrollViewer>

</UserControl>
