<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NervaOneWalletMiner.ViewModels"
			 mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="550"
			 x:DataType="vm:DaemonViewModel"
             x:Class="NervaOneWalletMiner.Views.DaemonView"
             SizeChanged="DaemonView_SizeChanged">
	<Design.DataContext>
		<vm:DaemonViewModel/>
	</Design.DataContext>

	<ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
	<Grid RowDefinitions="Auto,Auto">
		<Grid Grid.Row="0">
			<StackPanel Orientation="Vertical" HorizontalAlignment="Stretch"
						Spacing="5" Margin="10" MaxWidth="650">

				<Grid Name="grdHeader" ColumnDefinitions="Auto,*,Auto">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<!-- Component 1: Icon + Label -->
					<Grid Grid.Row="0" Grid.Column="0"
						  ColumnDefinitions="32,Auto"
						  VerticalAlignment="Center"
						  Margin="0,0,5,0">
						<Image Grid.Column="0" Name="imgCoinIcon"/>
						<Label Grid.Column="1" Content="Daemon"
							   Height="24" Margin="5,0,0,0"/>
					</Grid>

					<!-- Component 2: Threads + Button together -->
					<StackPanel Grid.Row="0" Grid.Column="2"
								Name="spThreadsAndButton"								
								Orientation="Horizontal"
								Spacing="10"
								Margin="0,10,5,0"
								VerticalAlignment="Center">
						<Label Content="Threads:" VerticalAlignment="Center"/>
						<ComboBox Name="cbxThreads"
								  Width="70"
								  SelectionChanged="cbxThreads_SelectionChanged"
								  IsEnabled="{Binding IsNumThreadsEnabled}"/>
						<Button Name="btnStartStopMining"
								Content="{Binding StartStopMining}"
								Click="StartStopMining_Clicked"
								VerticalAlignment="Center"/>
					</StackPanel>
				</Grid>

				<Grid Name="grdStats" ColumnDefinitions="200,*,200" Margin="0,10,5,0">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<!-- Component 3: Daemon stats -->
					<Grid Grid.Row="0" Grid.Column="0"
						  ColumnDefinitions="100,100"						  
						  Margin="0,10,5,0">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<Label Grid.Row="0" Grid.Column="0"
							   Content="Net Height:"/>
						<Label Grid.Row="0" Grid.Column="1"
							   Content="{Binding NetHeight}"
							   Width="150"
							   HorizontalAlignment="Left"/>
						<Label Grid.Row="1" Grid.Column="0"
							   Content="Your Height:"/>
						<Label Grid.Row="1" Grid.Column="1"
							   Content="{Binding YourHeight}"
							   Width="150"
							   HorizontalAlignment="Left"/>
						<Label Grid.Row="2" Grid.Column="0"
							   Content="Net Hash:"/>
						<Label Grid.Row="2" Grid.Column="1"
							   Content="{Binding NetHash}"
							   Width="150"
							   HorizontalAlignment="Left"/>
						<Label Grid.Row="3" Grid.Column="0"
							   Content="Run Time:"/>
						<Label Grid.Row="3" Grid.Column="1"
							   Content="{Binding RunTime}"
							   Width="150"
							   HorizontalAlignment="Left"/>
					</Grid>

					<!-- Component 4: Miner status -->
					<Grid Grid.Row="0" Grid.Column="2"
						  Name="grdMinerStats"
						  ColumnDefinitions="100,100"
						  Margin="0,10,5,0">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<Label Grid.Row="0" Grid.Column="0"
							   Content="Miner:"/>
						<Label Grid.Row="0" Grid.Column="1" 
							   Content="{Binding MinerMessage}"
							   Width="150"
							   HorizontalAlignment="Left"/>
						<Label Grid.Row="1" Grid.Column="0"
							   Content="Hash Rate:"
							   IsVisible="{Binding IsMiningActive}"/>
						<Label Grid.Row="1" Grid.Column="1"
							   Content="{Binding YourHash}"
							   Width="150"
							   HorizontalAlignment="Left"
							   IsVisible="{Binding IsMiningActive}"/>
						<Label Grid.Row="2" Grid.Column="0"
							   Content="Block Time:"
							   IsVisible="{Binding IsMiningActive}"/>
						<Label Grid.Row="2" Grid.Column="1"
							   Content="{Binding BlockTime}"
							   Width="150"
							   HorizontalAlignment="Left"
							   IsVisible="{Binding IsMiningActive}"/>
						<Label Grid.Row="3" Grid.Column="0"
							   Content="Address:"
							   IsVisible="{Binding IsMiningActive}"/>
						<Label Grid.Row="3" Grid.Column="1"
							   Content="{Binding MiningAddress}"
							   Width="150" HorizontalAlignment="Left"
							   IsVisible="{Binding IsMiningActive}"/>
					</Grid>
				</Grid>

			</StackPanel>
		</Grid>

		<Grid Grid.Row="1">
			<DataGrid Name="dgConnections"
					  ItemsSource="{Binding Connections}"
					  AutoGenerateColumns="False"
					  GridLinesVisibility="Horizontal"
					  IsReadOnly="True"
					  Margin="0,10,0,0"
					  MaxWidth="650">
				<DataGrid.Styles>
					<Style Selector="DataGridCell:current /template/ Grid#FocusVisual">
						<Setter Property="IsVisible" Value="false"/>
					</Style>
				</DataGrid.Styles>
				<DataGrid.Columns>
					<DataGridTemplateColumn Header="">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate>
								<Image Source="{Binding InOutIcon}" Height="15"/>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>
					<DataGridTextColumn Header="Address"
										MinWidth="100"
										Width="*"
										Binding="{Binding Address}"/>
					<DataGridTextColumn Header="Height"
										Binding="{Binding Height}"/>
					<DataGridTextColumn Header="Live Time"
										Binding="{Binding LiveTime}"/>
					<DataGridTextColumn Header="State"
										Binding="{Binding State}"/>
				</DataGrid.Columns>
			</DataGrid>
		</Grid>
	</Grid>
	</ScrollViewer>

</UserControl>
