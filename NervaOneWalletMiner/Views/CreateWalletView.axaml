<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NervaOneWalletMiner.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:DataType="vm:CreateWalletViewModel"
             x:Class="NervaOneWalletMiner.Views.CreateWalletView">

	<Design.DataContext>
		<vm:CreateWalletViewModel/>
	</Design.DataContext>

	<ScrollViewer>
		<StackPanel HorizontalAlignment="Stretch"
					Spacing="5"
					Margin="10"
					MaxWidth="650">

			<Grid ColumnDefinitions="32,*">
				<Image Grid.Column="0"
					   Name="imgCoinIcon"/>
				<Label Grid.Column="1"
					   Content="Create New Wallet"
					   Height="24"
					   Margin="5,0,0,0"/>
			</Grid>

			<Label Content="Wallet Name" Margin="0,10,0,0"/>
			<TextBox Name="tbxWalletName"
					 PlaceholderText="Enter wallet name"/>

			<Label Content="Password" Margin="0,15,0,0"/>
			<DockPanel>
				<Button Name="btnShowHidePassword"
						DockPanel.Dock="Right"
						Content="Show"
						Margin="10,0,0,0"
						IsTabStop="False"
						Click="ShowHidePassword_Clicked"/>
				<TextBox Name="tbxPassword"
						 PlaceholderText="Enter wallet password"
						 PasswordChar="*"
						 RevealPassword="False"/>
			</DockPanel>

			<Label Content="Language" Margin="0,15,0,0"/>
			<ComboBox Name="cbxLanguage" HorizontalAlignment="Stretch"/>

			<StackPanel Orientation="Horizontal" Spacing="10" Margin="0,20,0,0">
				<Button Name="btnOk"
						Content="Create"
						Click="OkButton_Clicked"/>
				<Button Name="btnCancel"
						Content="Cancel"
						Click="CancelButton_Clicked"/>
			</StackPanel>

		</StackPanel>
	</ScrollViewer>

</UserControl>
