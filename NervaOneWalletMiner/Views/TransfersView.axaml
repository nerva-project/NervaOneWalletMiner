<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:NervaOneWalletMiner.ViewModels"
             xmlns:dg="clr-namespace:NervaOneWalletMiner.Objects.DataGrid"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="550"
             x:DataType="vm:TransfersViewModel"
             x:Class="NervaOneWalletMiner.Views.TransfersView"
             SizeChanged="TransfersView_SizeChanged">

	<Design.DataContext>
		<vm:TransfersViewModel/>
	</Design.DataContext>

	<Grid RowDefinitions="Auto, *">
		<StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Stretch"
					Spacing="5" Margin="10" MaxWidth="650">

			<Grid Name="grdHeader" ColumnDefinitions="Auto,*,Auto">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<Grid Grid.Row="0" Grid.Column="0"
					  ColumnDefinitions="32,Auto"
					  VerticalAlignment="Center"
					  Margin="0,0,5,0">
					<Image Grid.Column="0" Name="imgCoinIcon"/>
					<Label Grid.Column="1" Content="Transfers"
						   Height="24" Margin="5,0,0,0"/>
				</Grid>

				<Button Grid.Row="0" Grid.Column="2"
						Name="btnTransactionDetails"
						Content="Transaction Details"
						Margin="0,0,5,0"
						Click="TransactionDetails_Clicked"/>
			</Grid>
		</StackPanel>

		<DataGrid Grid.Row="1" ItemsSource="{Binding Transactions}"
					  Name="dtgTransactions"
					  AutoGenerateColumns="False"
					  GridLinesVisibility="Horizontal"
					  IsReadOnly="True"
					  Margin="0,20,0,0"
					  MaxWidth="650"
					  DoubleTapped="TransactionDetails_DoubleTapped">
				<DataGrid.Styles>
					<Style Selector="DataGridCell:current /template/ Grid#FocusVisual">
						<Setter Property="IsVisible" Value="false" />
					</Style>
				</DataGrid.Styles>
				<DataGrid.Columns>
					<DataGridTemplateColumn Header="">
						<DataTemplate DataType="dg:Transfer">
							<Image Source="{Binding Icon}" Height="15"/>
						</DataTemplate>
					</DataGridTemplateColumn>				
					<DataGridTextColumn Header="Height"
										Binding="{Binding Height}"/>
					<DataGridTextColumn Header="Time"
										MinWidth="120"
										Width="*"
										Binding="{Binding Timestamp}"/>
					<DataGridTextColumn Header="Amount"
										Binding="{Binding Amount}"/>
					<DataGridTextColumn Header="Address"
										Binding="{Binding AddressShort}"/>
				</DataGrid.Columns>
				<DataGrid.ContextMenu>
					<ContextMenu>
						<MenuItem Header="Transaction Details"
								  Click="TransactionDetails_Clicked"/>
						<Separator/>
						<MenuItem Header="Export All"
								  Click="ExportAll_Clicked"/>
					</ContextMenu>
				</DataGrid.ContextMenu>
		</DataGrid>
	</Grid>

</UserControl>
