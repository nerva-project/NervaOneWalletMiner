<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:NervaOneWalletMiner.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="550"
             x:DataType="vm:DaemonSetupViewModel"
             x:Class="NervaOneWalletMiner.Views.DaemonSetupView">

	<Design.DataContext>
		<vm:DaemonSetupViewModel/>
	</Design.DataContext>

	<ScrollViewer>
		<StackPanel HorizontalAlignment="Stretch"
					ScrollViewer.AllowAutoHide="True"
					Spacing="5"
					Margin="10"
					MaxWidth="650">
			<Grid ColumnDefinitions="32,*">
				<Image Grid.Row="0"
					   Grid.Column="0"
					   Name="imgCoinIcon"/>
				<Label Grid.Row="0"
					   Grid.Column="1"
					   Content="Daemon Setup"
					   Height="24"
					   Margin="5,0,0,0"/>
			</Grid>

			<Button Name="btnOpenCliToolsFolder"
					Content="Open Client Tools Folder"
					DockPanel.Dock="Right"
					Margin="0,10,0,0"
					Click="OpenCliToolsFolder_Clicked"/>

			<Button Name="btnUpdateClientTools"
					Content="Update Client Tools"
					DockPanel.Dock="Right"
					Margin="0,10,0,0"
					Click="UpdateClientTools_Clicked"/>

			<Separator Margin="0,20,0,0"/>

			<RadioButton GroupName="NodeType"
					Name="FullNode"
					Margin="0,20,0,0"
					IsChecked="{Binding !IsWalletOnly}"
					IsCheckedChanged="NodeType_IsCheckedChanged">
				<TextBlock Text="Full Node: Blockchain runs on your device" TextWrapping="Wrap"/>
			</RadioButton>

			<RadioButton GroupName="NodeType"
					Name="RemoteNode"
					Margin="0,0,0,0"
					IsChecked="{Binding IsWalletOnly}"
					IsCheckedChanged="NodeType_IsCheckedChanged">
				<TextBlock Text="Wallet Only: Connect to remote node and get wallet functionality only" TextWrapping="Wrap"/>
			</RadioButton>

			<Separator Margin="0,20,0,0"/>

			<StackPanel Name="spWalletOnly" IsVisible="{Binding IsWalletOnly}">
				<TextBlock Name="lblRemoteNode"
						   Text="Remote Node Address or IP (Including port number)"
						   TextWrapping="Wrap"
						   Margin="0,10,0,10"/>
				<TextBox Name="tbxRemoteNode"
						 Text="{Binding RemoteNodeAddress, Mode=TwoWay}"/>
			</StackPanel>

			<StackPanel Name="spFullNode" IsVisible="{Binding !IsWalletOnly}">
				<Button Name="btnRestartWithCommand"
						Content="Restart with Optional Command"
						DockPanel.Dock="Right"
						Margin="0,10,0,0"
						Click="RestartWithCommand_Clicked"/>

				<Button Name="btnRestartWithQuickSync"
						Content="Restart with QuickSync"
						DockPanel.Dock="Right"
						Margin="0,10,0,0"
						Click="RestartWithQuickSync_Clicked"/>

				<Button Name="btnPublicNodeSetup"
						Content="Public Node Setup"
						DockPanel.Dock="Right"
						Margin="0,10,0,0"
						Click="PublicNodeSetup_Clicked"/>

				<Button Name="btnDownloadBlockchainDb"
						Content="Download Blockchain Db"
						DockPanel.Dock="Right"
						Margin="0,10,0,0"
						Click="DownloadBlockchainDb_Clicked"/>

				<Separator Margin="0,20,0,0"/>

				<Label Content="Mining Address" Margin="0,10,0,0"/>
				<TextBox Name="tbxMiningAddress"
						 Text="{Binding MiningAddress, Mode=TwoWay}"
						 Watermark="Address that will receive mining rewards"/>

				<Label Content="Data Directory" Margin="0,10,0,0"/>
				<Grid ColumnDefinitions="*,80">
					<TextBox Grid.Row="0"
							 Grid.Column="0"
							 Name="tbxDaemonDataDir"
							 Text="{Binding DataDir, Mode=TwoWay}"
							 Watermark="Blockchain database directory"/>

					<Button Grid.Row="0"
							Grid.Column="1"
							Name="btnChangeDataDir"
							Content="Change"
							Margin="10,0,0,0"
							Click="ChangeDataDir_Clicked"/>
				</Grid>

				<Label Content="Additional Startup Arguments" Margin="0,10,0,0"/>
				<TextBox Name="tbxAdditionalArguments"
						 Text="{Binding AdditionalArguments, Mode=TwoWay}"
						 Watermark="Additional arguments that will be sent to daemon when it starts"/>

				<Label Content="Port Number" Margin="0,10,0,0"/>
				<TextBox Name="tbxPortNumber"
						 Text="{Binding PortNumber, Mode=TwoWay}"
						 Watermark="Number - port that daemon will use to listen on"/>

				<Label Content="Log Level" Margin="0,10,0,0"/>
				<TextBox Name="tbxLogLevel"
						 Text="{Binding LogLevel, Mode=TwoWay}"
						 Watermark="Number - level at which daemon will write to log files"/>

				<CheckBox Name="cbxAutoStartMining"
						  Content="Auto start mining"
						  IsChecked="{Binding AutoStartMining, Mode=TwoWay}"
						  Margin="0,10,0,0"/>

				<CheckBox Name="cbxStopOnExit"
						  Content="Stop daemon on exit and coin switch"
						  IsChecked="{Binding StopOnExit, Mode=TwoWay}"
						  Margin="0,10,0,0"/>

				<CheckBox Name="cbxEnableConnectionsGuard"
						  Content="Enable connections guard"
						  IsChecked="{Binding EnableConnectionsGuard, Mode=TwoWay}"
						  Margin="0,10,0,0"/>

				<CheckBox Name="cbxUseNoAnalyticsFlag"
						  Content="Disable Analytics: Don't report node info to node map"
						  IsChecked="{Binding UseNoAnalyticsFlag, Mode=TwoWay}"
						  Margin="0,10,0,0"/>

				<CheckBox Name="cbxUseNoDnsFlag"
						  Content="Disable DNS: Don't use Domain Name System"
						  IsChecked="{Binding UseNoDnsFlag, Mode=TwoWay}"
						  Margin="30,10,0,0"
						  IsCheckedChanged="NoDns_IsCheckedChanged"/>

				<Separator Margin="0,20,0,0"/>

				<CheckBox Name="cbxThresholdEnabled"
						  Content="Enable Net Hash Threshold: Only mine if below (KH/s)"
						  IsChecked="{Binding ThresholdEnabled, Mode=TwoWay}"
						  Margin="0,10,0,0"
						  IsCheckedChanged="ThresholdEnabled_IsCheckedChanged"/>

				<NumericUpDown Name="hashThreshold"
							   Value="{Binding HashThreshold, Mode=TwoWay}"
							   Minimum="0"
							   FormatString="N0"
							   Width="160"
							   HorizontalAlignment="Left"
							   Margin="30,10,0,0"
							   IsEnabled="{Binding ThresholdEnabled}"/>
			</StackPanel>

			<Separator Margin="0,20,0,0"/>

			<Button Name="btnSaveSettings"
					Content="Save Settings"
					Click="SaveSettings_Clicked"
					Margin="0,10,0,0"/>

		</StackPanel>
	</ScrollViewer>

</UserControl>
