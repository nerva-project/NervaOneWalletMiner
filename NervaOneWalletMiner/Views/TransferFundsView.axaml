<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NervaOneWalletMiner.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="550"
             x:DataType="vm:TransferFundsViewModel"
             x:Class="NervaOneWalletMiner.Views.TransferFundsView">

	<Design.DataContext>
		<vm:TransferFundsViewModel/>
	</Design.DataContext>

	<ScrollViewer>
		<StackPanel HorizontalAlignment="Stretch"
					Spacing="5"
					Margin="10"
					MaxWidth="650">

			<Grid ColumnDefinitions="32,*">
				<Image Grid.Column="0"
					   Name="imgCoinIcon"/>
				<Label Grid.Column="1"
					   Content="Transfer Funds"
					   Height="24"
					   Margin="5,0,0,0"/>
			</Grid>

			<Label Content="Send From" Margin="0,10,0,0"/>
			<ComboBox Name="cbxSendFrom"
					  HorizontalAlignment="Stretch"
					  SelectionChanged="Account_SelectionChanged"/>

			<DockPanel Margin="0,5,0,0">
				<Label Content="Balance:" Width="100"/>
				<Label Name="lblBalance" Content="0"/>
			</DockPanel>
			<DockPanel>
				<Label Content="Unlocked:" Width="100"/>
				<Label Name="lblUnlocked" Content="0"/>
			</DockPanel>

			<DockPanel Margin="0,15,0,0">
				<Button Name="btnPickAddress"						
						Content="Address Book"
						DockPanel.Dock="Right"
						Click="PickAddress_Clicked"/>
				<Label Content="Send To"/>
			</DockPanel>
			<TextBox Name="tbxSendTo"
					 PlaceholderText="Required - recipient wallet address"/>

			<Label Content="Amount" Margin="0,15,0,0"/>
			<DockPanel>
				<ComboBox Name="cbxPriority"
						  DockPanel.Dock="Right"
						  Margin="10,0,0,0"/>
				<TextBox Name="tbxAmount"
						 PlaceholderText="Required - amount to send"/>
			</DockPanel>

			<Label Content="Payment Id" Margin="0,15,0,0"/>
			<DockPanel>
				<Button Name="btnGeneratePaymentId"
						DockPanel.Dock="Right"
						Content="Generate"
						Margin="10,0,0,0"
						Click="GeneratePaymentId_Clicked"/>
				<TextBox Name="tbxPaymentId"
						 PlaceholderText="Optional - payment Id"/>
			</DockPanel>

			<CheckBox Name="cbxSplitTransfer"
					  Content="Split Transfer"
					  Margin="0,10,0,0"/>

			<StackPanel Orientation="Horizontal" Spacing="10" Margin="0,20,0,0">
				<Button Name="btnOk"
						Content="Transfer"
						Click="OkButton_Clicked"/>
				<Button Name="btnCancel"
						Content="Cancel"
						Click="CancelButton_Clicked"/>
			</StackPanel>

		</StackPanel>
	</ScrollViewer>

</UserControl>
