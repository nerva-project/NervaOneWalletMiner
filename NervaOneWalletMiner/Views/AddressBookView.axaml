<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:NervaOneWalletMiner.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="550"
             x:DataType="vm:AddressBookViewModel"
             x:Class="NervaOneWalletMiner.Views.AddressBookView"
             SizeChanged="AddressBookView_SizeChanged">

	<Design.DataContext>
		<vm:AddressBookViewModel/>
	</Design.DataContext>

	<Grid RowDefinitions="Auto,*">
		<StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Stretch"
					Spacing="5" Margin="10" MaxWidth="650">

				<Grid Name="grdHeader" ColumnDefinitions="Auto,*,Auto">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<!-- Icon + Label -->
					<Grid Grid.Row="0" Grid.Column="0"
						  ColumnDefinitions="32,Auto"
						  VerticalAlignment="Center"
						  Margin="0,0,5,0">
						<Image Grid.Column="0" Name="imgCoinIcon"/>
						<Label Grid.Column="1"
							   Content="Address Book"
							   Height="24"
							   Margin="5,0,0,0"/>
					</Grid>

					<!-- Add + Edit + Transfer buttons -->
					<StackPanel Grid.Row="0" Grid.Column="2"
								Name="spHeaderButtons"
								Orientation="Horizontal"
								Spacing="10"
								Margin="0,0,5,0"
								VerticalAlignment="Center">
						<Button Name="btnAdd"
								Content="Add"
								Click="Add_Clicked"/>
						<Button Name="btnEdit"
								Content="Edit"
								Click="Edit_Clicked"/>
						<Button Name="btnTransfer"
								Content="Transfer Funds"
								Click="Transfer_Clicked"/>
					</StackPanel>
				</Grid>

		</StackPanel>

		<DataGrid Grid.Row="1" Name="dtgAddressBook"
					  AutoGenerateColumns="False"
					  GridLinesVisibility="Horizontal"
					  IsReadOnly="True"
					  Margin="0,10,0,0"
					  MaxWidth="650"
					  ItemsSource="{Binding Addresses}"
					  DoubleTapped="AddressBook_DoubleTapped">
				<DataGrid.Styles>
					<Style Selector="DataGridCell:current /template/ Grid#FocusVisual">
						<Setter Property="IsVisible" Value="false" />
					</Style>
				</DataGrid.Styles>
				<DataGrid.Columns>
					<DataGridTextColumn Header="Name"
										Width="*"
										Binding="{Binding Name, Mode=OneWay}"/>
					<DataGridTextColumn Header="Description"
										Width="*"
										Binding="{Binding Description, Mode=OneWay}"/>
					<DataGridTextColumn Header="Address"
										MinWidth="120"
										Width="*"
										Binding="{Binding Address, Mode=OneWay}"/>
					<DataGridTextColumn Header="Payment Id"
										Width="*"
										Binding="{Binding PaymentId, Mode=OneWay}"/>
				</DataGrid.Columns>
				<DataGrid.ContextMenu>
					<ContextMenu>
						<MenuItem Header="Edit Address"
								  Click="Edit_Clicked"/>
						<MenuItem Header="Transfer to Address"
								  Click="Transfer_Clicked"/>
						<Separator/>
						<MenuItem Header="Delete Address"
								  Click="Delete_Clicked"/>
					</ContextMenu>
				</DataGrid.ContextMenu>
		</DataGrid>
	</Grid>

</UserControl>
