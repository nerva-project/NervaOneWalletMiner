<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NervaOneWalletMiner.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="600"
             x:DataType="vm:DisplayKeysSeedViewModel"
             x:Class="NervaOneWalletMiner.Views.DisplayKeysSeedView">

	<Design.DataContext>
		<vm:DisplayKeysSeedViewModel/>
	</Design.DataContext>

	<ScrollViewer>
		<StackPanel HorizontalAlignment="Stretch"
					Spacing="5"
					Margin="10"
					MaxWidth="650">

			<Grid ColumnDefinitions="32,*">
				<Image Grid.Column="0"
					   Name="imgCoinIcon"/>
				<Label Grid.Column="1"
					   Content="Keys and Seed Phrase"
					   Height="24"
					   Margin="5,0,0,0"/>
			</Grid>

			<Separator Margin="0,5,0,0"/>

			<TextBlock Name="tbkMessage"
					   TextWrapping="Wrap"
					   Margin="0,5,0,5"/>

			<Label Content="Public View Key"/>
			<DockPanel>
				<Button Name="btnCopyPublicViewKeyToClipboard"
						DockPanel.Dock="Right"
						Content="Copy"
						Margin="10,0,0,0"
						Click="CopyPublicViewKeyToClipboard_Clicked"/>
				<TextBox Name="tbxPublicViewKey"/>
			</DockPanel>

			<Label Content="Private View Key" Margin="0,10,0,0"/>
			<DockPanel>
				<Button Name="btnCopyPrivateViewKeyToClipboard"
						DockPanel.Dock="Right"
						Content="Copy"
						Margin="10,0,0,0"
						Click="CopyPrivateViewKeyToClipboard_Clicked"/>
				<Button Name="btnShowHidePrivateViewKey"
						DockPanel.Dock="Right"
						Content="Show"
						Margin="10,0,0,0"
						Click="ShowHidePrivateViewKey_Clicked"/>
				<TextBox Name="tbxPrivateViewKey"
						 PasswordChar="*"/>
			</DockPanel>

			<Separator Margin="0,15,0,5"/>

			<Label Content="Public Spend Key"/>
			<DockPanel>
				<Button Name="btnCopyPublicSpendKeyToClipboard"
						DockPanel.Dock="Right"
						Content="Copy"
						Margin="10,0,0,0"
						Click="CopyPublicSpendKeyToClipboard_Clicked"/>
				<TextBox Name="tbxPublicSpendKey"/>
			</DockPanel>

			<Label Content="Private Spend Key" Margin="0,10,0,0"/>
			<DockPanel>
				<Button Name="btnCopyPrivateSpendKeyToClipboard"
						DockPanel.Dock="Right"
						Content="Copy"
						Margin="10,0,0,0"
						Click="CopyPrivateSpendKeyToClipboard_Clicked"/>
				<Button Name="btnShowHidePrivateSpendKey"
						DockPanel.Dock="Right"
						Content="Show"
						Margin="10,0,0,0"
						Click="ShowHidePrivateSpendKey_Clicked"/>
				<TextBox Name="tbxPrivateSpendKey"
						 PasswordChar="*"/>
			</DockPanel>

			<Separator Margin="0,15,0,5"/>

			<Label Content="Mnemonic Seed"/>
			<DockPanel>
				<StackPanel DockPanel.Dock="Right" Spacing="5" Margin="10,0,0,0">
					<Button Name="btnShowHideSeed"
							Content="Show"
							Click="ShowHideSeed_Clicked"/>
					<Button Name="btnCopySeedToClipboard"
							Content="Copy"
							Click="CopySeedToClipboard_Clicked"/>
				</StackPanel>
				<TextBox Name="tbxMnemonicSeed"
						 PasswordChar="*"
						 AcceptsReturn="True"
						 TextWrapping="Wrap"
						 Height="60"/>
			</DockPanel>

			<Button Name="btnClose"
					Content="Close"
					Margin="0,15,0,0"
					Click="CloseButton_Clicked"/>

		</StackPanel>
	</ScrollViewer>

</UserControl>
