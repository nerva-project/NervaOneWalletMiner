<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:NervaOneWalletMiner.ViewModels"
			 xmlns:obj="clr-namespace:NervaOneWalletMiner.Objects"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="550"
			 x:DataType="vm:SettingsViewModel"
             x:Class="NervaOneWalletMiner.Views.SettingsView">

	<Design.DataContext>
		<vm:SettingsViewModel/>
	</Design.DataContext>
	
	<StackPanel HorizontalAlignment="Stretch"
				Spacing="5"
				Margin="10"
				MaxWidth="650">
		<Grid ColumnDefinitions="32,*">
			<Image Grid.Row="0"
				   Grid.Column="0"
				   Name="imgCoinIcon"/>
			<Label Grid.Row="0"
				   Grid.Column="1"
				   Content="Settings"
				   Height="24"
				   Margin="5,0,0,0"/>
		</Grid>
		
		<Button Name="btnOpenLogsFolder"
				Command="{Binding OpenLogsFolderCommand}"
				Content="Open Logs Folder"
				Margin="0,10,0,0"/>

		<Button Name="btnViewAppLogs"
				Content="View App Logs"
				Margin="0,10,0,0"
				Click="ViewAppLogs_Clicked"/>

		<Button Name="btnViewCliLogs"
				Content="View CLI Tool Logs"
				Margin="0,10,0,0"
				Click="ViewCliLogs_Clicked"/>

		<Button Name="btnViewWalletExports"
				Content="View Wallet Exports"
				Margin="0,10,0,0"
				Click="ViewWalletExports_Clicked"/>

		<Separator Margin="0,20,0,0"/>
		
		<Label Content="Active Coin" Margin="0,10,0,0"/>
		<ComboBox Name="cbxCoin" ItemsSource="{Binding CoinList}">
			<ComboBox.ItemTemplate>
				<DataTemplate x:DataType="obj:CoinListItem">
					<Grid ColumnDefinitions="24,*">
						<Image Grid.Column="0"
							   Height="32"
							   Source="{Binding Logo}"/>
						<TextBlock Grid.Column="1"
								   Padding="5,7,0,0"
								   Text="{Binding DisplayName}"/>
					</Grid>
				</DataTemplate>
			</ComboBox.ItemTemplate>
		</ComboBox>	

		<Label Content="Application Theme" Margin="0,10,0,0"/>
		<ComboBox Name="cbxThemeVariants"
				  DisplayMemberBinding="{Binding Key, x:DataType=ThemeVariant}"
				  SelectedIndex="0">
			<ComboBox.Items>
				<ThemeVariant>Default</ThemeVariant>
				<ThemeVariant>Light</ThemeVariant>
				<ThemeVariant>Dark</ThemeVariant>
			</ComboBox.Items>
		</ComboBox>
		
		<Separator Margin="0,20,0,0"/>

		<Button Name="btnSaveSettings"
				Content="Save Settings"
				Click="SaveSettings_Clicked"
				Margin="0,10,0,0" />
		
	</StackPanel>
	
</UserControl>
