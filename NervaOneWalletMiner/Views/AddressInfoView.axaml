<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NervaOneWalletMiner.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="600"
             x:DataType="vm:AddressInfoViewModel"
             x:Class="NervaOneWalletMiner.Views.AddressInfoView">

	<Design.DataContext>
		<vm:AddressInfoViewModel/>
	</Design.DataContext>

	<ScrollViewer>
		<StackPanel HorizontalAlignment="Stretch"
					Spacing="5"
					Margin="10"
					MaxWidth="650">

			<Grid ColumnDefinitions="32,*">
				<Image Grid.Column="0"
					   Name="imgCoinIcon"/>
				<Label Grid.Column="1"
					   Content="Address Information"
					   Height="24"
					   Margin="5,0,0,0"/>
			</Grid>

			<Label Content="Select Account to View Full Address"
				   Margin="0,10,0,0"/>
			<ComboBox Name="cbxAccount"
					  HorizontalAlignment="Stretch"
					  SelectionChanged="AccountSelectionChanged"/>

			<Label Content="Wallet Address" Margin="0,15,0,0"/>
			<DockPanel>
				<Button Name="btnCopyWalletToClipboard"
						DockPanel.Dock="Right"
						Content="Copy"
						Margin="10,0,0,0"
						Click="CopyWalletToClipboard_Clicked"/>
				<TextBox Name="tbxWalletAddress"/>
			</DockPanel>

			<Label Content="Wallet Label" Margin="0,10,0,0"/>
			<DockPanel>
				<Button Name="btnSaveLabel"
						DockPanel.Dock="Right"
						Content="Save"
						Margin="10,0,0,0"
						Click="SaveLabel_Clicked"/>
				<TextBox Name="tbxWalletLabel"/>
			</DockPanel>

			<Separator Margin="0,20,0,0"/>

			<Button Name="btnMakeIntegratedAddress"
					Content="Make Integrated Address"
					Click="MakeIntegratedAddress_Clicked"
					Margin="0,15,0,0"/>

			<Label Content="Integrated Address" Margin="0,15,0,0"/>
			<DockPanel>
				<Button Name="btnCopyIntegratedAddressToClipboard"
						DockPanel.Dock="Right"
						Content="Copy"
						Margin="10,0,0,0"
						Click="CopyIntegratedAddressToClipboard_Clicked"/>
				<TextBox Name="tbxIntegratedAddress"/>
			</DockPanel>

			<Label Content="Payment Id" Margin="0,15,0,0"/>
			<DockPanel>
				<Button Name="btnCopyPaymentIdToClipboard"
						DockPanel.Dock="Right"
						Content="Copy"
						Margin="10,0,0,0"
						Click="CopyPaymentIdToClipboard_Clicked"/>
				<TextBox Name="tbxPaymentId"/>
			</DockPanel>

			<Button Name="btnBack"
					Content="Back"
					Click="BackButton_Clicked"
					Margin="0,15,0,0"/>

		</StackPanel>
	</ScrollViewer>

</UserControl>
